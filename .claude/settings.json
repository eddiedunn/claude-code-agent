{
  "defaultMode": "dontAsk",

  "permissions": {
    "deny": [
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(dd *)",
      "Bash(shred *)",
      "Bash(truncate *)",

      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(nc *)",
      "Bash(netcat *)",
      "Bash(ncat *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(rsync *)",
      "Bash(ftp *)",
      "Bash(telnet *)",

      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(doas *)",
      "Bash(chmod 777 *)",
      "Bash(chown *)",

      "Bash(pip install *)",
      "Bash(npm install *)",
      "Bash(npm ci *)",
      "Bash(brew install *)",
      "Bash(brew upgrade *)",

      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git rebase *)",
      "Bash(git filter-branch *)",

      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gcloud/**)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)"
    ],

    "ask": [
      "Bash(git push *)",
      "Bash(git merge *)",
      "Bash(git stash *)",
      "Bash(uv pip install *)",
      "Bash(kill *)",
      "Bash(pkill *)"
    ],

    "allow": [
      "Bash(git worktree *)",
      "Bash(git status *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(git log *)",
      "Bash(git diff *)",

      "Bash(uv run *)",
      "Bash(uv sync *)",
      "Bash(uv pip list *)",

      "Bash(tmux new-session *)",
      "Bash(tmux new-window *)",
      "Bash(tmux send-keys *)",
      "Bash(tmux list-sessions *)",
      "Bash(tmux list-windows *)",
      "Bash(tmux kill-window *)",
      "Bash(tmux kill-session *)",

      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(touch *)",

      "Bash(jq *)",
      "Bash(date *)",
      "Bash(ps *)"
    ]
  },

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/bash-guard.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[WARN] settings changed during session\" >> /tmp/grind-config-changes.log"
          }
        ]
      }
    ]
  }
}
